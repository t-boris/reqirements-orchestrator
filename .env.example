# =============================================================================
# MARO Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-xxx
LLM_MODEL_MAIN=gpt-5-mini
LLM_MODEL_SUMMARIZE=gpt-5-nano

# Optional: Alternative LLM providers (for adapter switching)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Slack Configuration
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_SIGNING_SECRET=xxx
SLACK_APP_TOKEN=xapp-xxx

# -----------------------------------------------------------------------------
# Jira Configuration
# -----------------------------------------------------------------------------
JIRA_URL=https://your-domain.atlassian.net
JIRA_USER=your-email@example.com
JIRA_API_TOKEN=xxx

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://maro:maro@localhost:5432/maro
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
# Interval for periodic graph save to PostgreSQL (seconds)
GRAPH_SAVE_INTERVAL_SECONDS=30

# Threshold for context summarization (percentage of context window)
CONTEXT_THRESHOLD_PERCENT=80

# Web dashboard polling interval (milliseconds)
POLLING_INTERVAL_MS=5000

# Rate limiting: leaky bucket tokens per second
RATE_LIMIT_TOKENS_PER_SECOND=10

# Retry configuration
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=false
