# =============================================================================
# MARO Production Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL_MAIN=gpt-4o-mini
LLM_MODEL_SUMMARIZE=gpt-4o-mini

# -----------------------------------------------------------------------------
# Slack Configuration
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# -----------------------------------------------------------------------------
# Jira Configuration
# -----------------------------------------------------------------------------
JIRA_URL=https://your-domain.atlassian.net
JIRA_USER=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# -----------------------------------------------------------------------------
# Database Configuration (internal Docker network)
# -----------------------------------------------------------------------------
# Set a strong password for production!
POSTGRES_PASSWORD=change_me_to_a_strong_password
DATABASE_URL=postgresql+asyncpg://maro:${POSTGRES_PASSWORD}@postgres:5432/maro
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
GRAPH_SAVE_INTERVAL_SECONDS=30
CONTEXT_THRESHOLD_PERCENT=80
POLLING_INTERVAL_MS=5000
RATE_LIMIT_TOKENS_PER_SECOND=10
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=false
