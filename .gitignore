.mypy_cache/
.dmypy.json
dmypy.json

# Node (frontend)
web/node_modules/
web/dist/
web/.cache/

# Logs
*.log
logs/

# Local development
.env.local
.env.*.local
*.local.json

# Database
*.db
*.sqlite

# Docker
docker-compose.override.yml

# OS
.DS_Store
Thumbs.db

# Secrets (never commit!)
secrets/
*.pem
*.key
credentials.json
